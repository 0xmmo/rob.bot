{
  "name": "rob.bot",
  "version": "2.0.0",
  "description": "AI chat application with PDF-powered RAG",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "start:tui": "tsx tui/index.ts",
    "test:e2e": "tsx test/e2e.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.95",
    "@types/blessed": "^0.1.27",
    "@types/node": "^25.3.0",
    "blessed": "^0.1.81",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "pdfjs-dist": "^5.4.296",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unpdf": "^1.4.0",
    "vectra": "^0.9.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "concurrently": "^9.1.0"
  }
}
